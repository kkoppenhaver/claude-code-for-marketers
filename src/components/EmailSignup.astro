---
import { Image } from 'astro:assets';
import sarahPhoto from '../assets/images/sarah-sherman.jpg';

interface Props {
  headline?: string;
  description?: string;
  tagId?: string;
  buttonText?: string;
}

const {
  headline = "Master Claude Code in 15 minutes a day",
  description = "Join our free 7-day email course and learn how to use Claude Code for your marketing work. Then, get notified when we publish new use cases and ways to stay ahead of the curve.",
  tagId,
  buttonText = "Send me the free course",
} = Astro.props;

const FORM_ID = "8947118";
const formAction = `https://app.kit.com/forms/${FORM_ID}/subscriptions`;
---

<div class="signup-box">
  <div class="signup-header">
    <span class="prompt">&gt;</span>
    <span class="headline">{headline}</span>
  </div>
  <p class="signup-description">{description}</p>
  <form action={formAction} method="post" class="signup-form">
    {tagId && <input type="hidden" name="tags[]" value={tagId} />}
    <div class="input-group">
      <label for="email-input" class="sr-only">Email address</label>
      <input
        type="email"
        name="email_address"
        id="email-input"
        placeholder="you@example.com"
        required
        autocomplete="email"
      />
      <button type="submit">{buttonText}</button>
    </div>
  </form>
  <p class="signup-note">No spam. Unsubscribe anytime.</p>
  <div class="testimonial">
    <blockquote>
      <p>"I watched Keanan work magic with Claude [Code] in the terminal. My brain: 'It's far too technical!' 'Dark mode? Not for me!' ...I shipped 4 things in my first month."</p>
      <cite>
        <Image src={sarahPhoto} alt="Sarah Sherman" width={96} height={96} class="testimonial-avatar" />
        <div>
          <strong>Sarah Sherman</strong>
          <span>Community Builder at Retool</span>
        </div>
      </cite>
    </blockquote>
  </div>
</div>

<style>
  .signup-box {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.5rem;
    margin: 2rem 0;
  }

  .signup-header {
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .prompt {
    color: var(--color-accent);
    font-weight: 700;
  }

  .headline {
    color: var(--color-text);
  }

  .signup-description {
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    margin-bottom: 1rem;
    line-height: 1.5;
  }

  .signup-form {
    margin-bottom: 0.75rem;
  }

  .input-group {
    display: flex;
    gap: 0.5rem;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  input[type="email"] {
    flex: 1;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    padding: 0.75rem 1rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    color: var(--color-text);
    transition: border-color 0.2s ease;
  }

  input[type="email"]::placeholder {
    color: var(--color-text-secondary);
    opacity: 0.6;
  }

  input[type="email"]:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  button[type="submit"] {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: 500;
    padding: 0.75rem 1.25rem;
    background: var(--color-accent);
    color: var(--color-bg);
    border: none;
    border-radius: 6px;
    cursor: pointer;
    transition: background-color 0.2s ease;
    white-space: nowrap;
  }

  button[type="submit"]:hover {
    background: var(--color-accent-hover);
  }

  .signup-note {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    opacity: 0.7;
  }

  .testimonial {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }

  .testimonial :global(blockquote) {
    margin: 0;
    padding: 0;
    padding-left: 1rem;
    border-left: 2px solid var(--color-accent);
    background: transparent;
    border-radius: 0;
  }

  .testimonial :global(blockquote p) {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin-bottom: 0.5rem;
    font-style: italic;
  }

  .testimonial :global(cite) {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-style: normal;
    font-family: var(--font-mono);
    font-size: 0.8rem;
  }

  .testimonial :global(cite div) {
    display: flex;
    flex-direction: column;
  }

  .testimonial :global(cite strong) {
    color: var(--color-text);
  }

  .testimonial :global(cite span) {
    color: var(--color-text-secondary);
  }

  .testimonial :global(.testimonial-avatar) {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  @media (max-width: 500px) {
    .input-group {
      flex-direction: column;
    }

    button[type="submit"] {
      width: 100%;
    }
  }
</style>
