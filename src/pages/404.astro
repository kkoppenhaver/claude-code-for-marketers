---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page not found"
  description="The page you're looking for doesn't exist. Browse our tutorials and guides for using Claude Code as a marketer."
>
  <section class="not-found">
    <div class="terminal-window">
      <div class="terminal-header">
        <span class="terminal-dot red"></span>
        <span class="terminal-dot yellow"></span>
        <span class="terminal-dot green"></span>
      </div>
      <div class="terminal-body">
        <p class="terminal-line"><span class="prompt">$</span> cat ./page.md</p>
        <p class="terminal-output error">Error 404: file not found</p>
      </div>
    </div>
    <h1>Nothing here</h1>
    <p class="message">This page doesn't exist, but there are plenty that do.</p>
    <div class="links">
      <a href="/" class="link-button">Back to home</a>
      <a href="/blog" class="link-button secondary">Browse all posts</a>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    text-align: center;
    padding: 3rem 0;
    max-width: 480px;
    margin: 0 auto;
  }

  .terminal-window {
    max-width: 320px;
    margin: 0 auto 2.5rem;
    background: #1C1917;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
    border: 1px solid #292524;
  }

  .terminal-header {
    background: #292524;
    padding: 0.75rem 1rem;
    display: flex;
    gap: 0.5rem;
  }

  .terminal-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .terminal-dot.red { background: #ff5f56; }
  .terminal-dot.yellow { background: #ffbd2e; }
  .terminal-dot.green { background: #27ca40; }

  .terminal-body {
    padding: 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    text-align: left;
    color: #FAFAF9;
  }

  .terminal-line {
    margin-bottom: 0.5rem;
  }

  .terminal-line .prompt {
    color: #DA7756;
    margin-right: 0.5rem;
  }

  .terminal-output.error {
    color: #ff5f56;
    padding-left: 1rem;
  }

  .not-found h1 {
    font-size: 2rem;
    margin-bottom: 0.75rem;
  }

  .message {
    color: var(--color-text-secondary);
    font-size: 1.05rem;
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .links {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .link-button {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: 500;
    padding: 0.75rem 1.5rem;
    border-radius: 6px;
    background: var(--color-accent);
    color: #fff;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .link-button:hover {
    opacity: 0.9;
    text-decoration: none;
  }

  .link-button.secondary {
    background: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-text);
  }

  .link-button.secondary:hover {
    border-color: var(--color-accent);
    background: var(--color-bg-secondary);
  }
</style>
